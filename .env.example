# Database
DATABASE_URL=sqlite:///./escalation.db

# Keep false for local development and automated tests.
ENABLE_EXTERNAL_NOTIFICATIONS=false

# Twilio: SMS and WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM_NUMBER=
# Example: whatsapp:+14155238886
TWILIO_WHATSAPP_FROM_NUMBER=

# SendGrid: email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Vakil Escalation

# Main application dashboard webhook (optional)
DASHBOARD_WEBHOOK_URL=
DASHBOARD_WEBHOOK_TOKEN=

